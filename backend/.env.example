# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/visa_consultancy?schema=public"

# JWT
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_REFRESH_SECRET="change-me-to-another-random-64-char-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_CURRENCY="usd"
STRIPE_AMOUNT_CENTS=5000

# Resend (email)
RESEND_API_KEY="re_..."
RESEND_FROM="noreply@travelpaa.com"

# AWS S3
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="visa-documents"

# Server
PORT=4000
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3000"
